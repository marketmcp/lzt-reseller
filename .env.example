# ════════════════════════════════════════════════════════════════════════
#  VAULT — переменные окружения
#  Скопируйте этот файл в .env и заполните. .env НИКОГДА не коммитится.
#  Сервер читает .env сам (без зависимостей).
# ════════════════════════════════════════════════════════════════════════

# ── Сервер ──
PORT=3000
HOST=0.0.0.0
# Ставьте 1, если сайт за HTTPS (cookie станут Secure)
SECURE_COOKIE=0

# ── Доступ владельца (вход в админку: ваш-сайт/#admin) ──
# Вариант 1 (простой): пароль в открытом виде
OWNER_PASSWORD=поменяйте_меня
# Вариант 2 (безопаснее): sha256-хэш пароля. Если задан — используется он.
#   получить хэш:  node -e "console.log(require('crypto').createHash('sha256').update('ВАШ_ПАРОЛЬ').digest('hex'))"
# OWNER_PASSWORD_HASH=

# Секрет для подписи сессий. Сгенерируйте случайный:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── LZT Market API (СЕКРЕТ — только на сервере, в браузер не уходит) ──
# Один токен (scope "market") из ЛК LZT. Без него — ДЕМО-режим.
LZT_TOKEN=
# Несколько токенов через запятую — грузит каталог в N раз быстрее (round-robin):
# LZT_TOKENS=token1,token2,token3
LZT_HOST=prod-api.lzt.market
# Тайминги на ОДИН токен (мс): поиск ~20/мин, общий ~100/мин. Менять не обязательно.
# LZT_SEARCH_GAP_MS=3100
# LZT_GEN_GAP_MS=600

# ── Общий каталог (нода) и федерация ──
# Период фонового обхода категорий, мин (0 = выключить).
CATALOG_SYNC_MIN=10
# Какие категории обходить (через запятую). Пусто = дефолтный список.
# CATALOG_CATEGORIES=steam,fortnite,discord,telegram
# Федерация: тянуть публичный каталог у доверенных нод (через запятую).
# Делятся ТОЛЬКО публичные листинги (без токенов и кредов). Покупка валидируется вживую.
# CATALOG_PEERS=https://friend-shop.example.com

# ── Telegram-уведомления (опционально) ──
# Бот для оповещений о покупках/пополнениях. Токен у @BotFather, chat id у @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Оплата криптой: CryptoBot / Crypto Pay (опционально) ──
# Токен в @CryptoBot → Crypto Pay → Create App. Без него крипто-метод работает как демо.
CRYPTOBOT_TOKEN=
# Для тестовой сети: CRYPTOBOT_HOST=testnet-pay.crypt.bot
CRYPTOBOT_HOST=pay.crypt.bot

# ── Хранилище настроек магазина (JSON, пишется из админки) ──
# CONFIG_FILE=./data/store-config.json
